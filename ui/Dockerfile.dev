FROM node:20-alpine

WORKDIR /app

# Copy package files first
COPY ui/package*.json ./

# Install dependencies as root to avoid permission issues
USER root
RUN npm install

# Copy source
COPY ui/ ./

# Set correct permissions for mounted volume
RUN chown -R node:node /app

# Switch to non-root user
USER node

EXPOSE 3000
CMD ["npm", "run", "dev"]