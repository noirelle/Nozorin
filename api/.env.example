# Server
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:3000

# JWT / Authentication
JWT_SECRET=replace_with_secure_random_string
JWT_EXPIRY=30d
JWT_ACCESS_EXPIRY=10s
JWT_REFRESH_SECRET=replace_with_secure_random_string
JWT_REFRESH_EXPIRY=7d
ADMIN_PANEL_PASSWORD=replace_with_secure_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=root
REDIS_TTL=604800

# MySQL
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_USER=nozorin
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=nozorin_db

# Socket / Realtime Service
SOCKET_SERVICE_URL=http://realtime:3002
INTERNAL_API_SECRET=replace_with_secure_internal_secret